# ── Database ───────────────────────────────────────────────────────────────────
# Production: PostgreSQL connection string from Render
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/mes_db?sslmode=require"

# Local dev with PostgreSQL (if you have one running locally):
# DATABASE_URL="postgresql://postgres:password@localhost:5432/mes_dev"

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters. Change before going live.
SESSION_SECRET="replace-with-64-char-random-hex-string"

# ── File Uploads (Vercel Blob) ─────────────────────────────────────────────────
# Get this from: Vercel Dashboard -> Storage -> Blob -> Create Store -> .env.local
# Leave empty for local dev (files will be saved to public/uploads/ instead)
BLOB_READ_WRITE_TOKEN=""

# ── CORS ───────────────────────────────────────────────────────────────────────
# Your Vercel deployment URL. Restricts API to same origin.
# Leave as * for development. Set in production.
ALLOWED_ORIGIN="https://your-app.vercel.app"

# ── Optional: Machine-to-Machine API Key ──────────────────────────────────────
# Used by RFID gateways, PLCs, or external systems calling the API
# MES_API_KEY="your-secret-api-key"

# ── Optional: MQTT Broker (for machine telemetry) ─────────────────────────────
# MQTT_BROKER_URL="mqtt://broker.hivemq.com:1883"
# MQTT_USERNAME=""
# MQTT_PASSWORD=""
