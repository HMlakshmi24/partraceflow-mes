# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ───────────────────────────────────────────────────────
.next/
out/
build/

# ── Database (SQLite local dev file — never commit) ───────────────────────────
prisma/dev.db
prisma/dev.db-journal
prisma/*.db
prisma/*.db-shm
prisma/*.db-wal

# ── Migrations (generated — never commit, run on server instead) ──────────────
# Uncomment the line below ONLY if you want to exclude migration history
# prisma/migrations/

# ── Environment variables (NEVER commit real secrets) ─────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
.env.test

# ── Uploaded files (local dev only — production uses Vercel Blob) ─────────────
public/uploads/

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel/

# ── Prisma generated client ────────────────────────────────────────────────────
lib/generated/prisma/
node_modules/.prisma/

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Testing & coverage ─────────────────────────────────────────────────────────
coverage/

# ── OS / Editor ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/settings.json

# ── Logs ──────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── Misc dev/test scripts (not needed in repo) ────────────────────────────────
demo_result.txt
spc_result.txt
test-all-buttons.js
ERROR_DEMO_SCRIPT.js
verify_all.ts
